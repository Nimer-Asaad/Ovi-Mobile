// Ovi Mobile — Prisma schema
//
// Portability note:
// Every "enum-like" field below is a `String` constrained to a fixed set of
// values rather than a native Prisma `enum`, kept from the SQLite era of
// this project (SQLite has no native enum type). The canonical list of
// allowed values for each lives in `src/lib/constants.ts` and is mirrored as
// TypeScript string-literal union types in `src/types/index.ts`. Now that
// the datasource is PostgreSQL (Phase 29), these could optionally be
// promoted to real `enum` columns as a separate follow-up, without changing
// application code.
//
// Money note:
// All monetary fields are `Int`, storing the smallest currency unit
// (e.g. agorot for ILS) instead of `Decimal`, to avoid floating-point
// rounding issues — unchanged by the PostgreSQL move.
//
// Database note (Phase 29):
// Production/shared development now uses PostgreSQL (Supabase or
// equivalent) — see DATABASE_URL/DIRECT_URL in .env.example and
// DEPLOYMENT.md. `directUrl` is the non-pooled connection Prisma uses for
// `db push`/`migrate`; `url` is the runtime connection.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

/// Role values: "ADMIN" | "RETAIL_CUSTOMER" | "WHOLESALE_MERCHANT" | "SALES_REPRESENTATIVE"
/// See src/lib/constants.ts -> ROLES
model User {
  id           String    @id @default(cuid())
  role         String
  name         String
  email        String    @unique
  phone        String?
  passwordHash String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  /// Set on every successful login (email/password, Google, or registration
  /// auto-login) — see createSession() in src/lib/auth/session.ts.
  lastLoginAt  DateTime?
  /// Debounced "last seen" timestamp, refreshed by getSession() at most once
  /// every LAST_ACTIVE_REFRESH_MS — see src/lib/auth/session.ts.
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  merchantProfile            Merchant?
  salesRepresentativeProfile SalesRepresentative?

  ordersPlaced      Order[]             @relation("OrderCustomer")
  stockMovements    StockMovement[]     @relation("StockMovementCreatedBy")
  sessions          Session[]
  cart              Cart?
  activityEvents    UserActivityEvent[]
  auditLogsAsAdmin  AdminAuditLog[]     @relation("AuditLogAdmin")
  auditLogsAsTarget AdminAuditLog[]     @relation("AuditLogTarget")

  @@map("users")
}

/// MerchantStatus values: "PENDING" | "APPROVED" | "REJECTED" | "SUSPENDED"
/// Wholesale pricing is only visible once status = "APPROVED".
model Merchant {
  id            String               @id @default(cuid())
  userId        String               @unique
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName  String
  taxId         String?
  status        String               @default("PENDING")
  approvedAt    DateTime?
  assignedRepId String?
  assignedRep   SalesRepresentative? @relation("RepMerchants", fields: [assignedRepId], references: [id])
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  orders Order[] @relation("OrderMerchant")

  @@map("merchants")
}

model SalesRepresentative {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode String   @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedMerchants Merchant[]     @relation("RepMerchants")
  carStockLocation  StockLocation?
  ordersCreated     Order[]        @relation("OrderCreatedByRep")
  stockRequests     StockRequest[]
  stockReturns      StockReturn[]

  @@map("sales_representatives")
}

// ---------------------------------------------------------------------------
// Auth
// ---------------------------------------------------------------------------

/// Opaque, DB-backed session. The cookie holds only this row's id — nothing
/// meaningful outside the database — so logout/revocation is a plain delete
/// and there is no signing secret to manage.
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Activity tracking & admin audit log
// ---------------------------------------------------------------------------

/// UserActivityEventType values:
/// "LOGIN" | "LOGOUT" | "PRODUCT_VIEWED" | "ADDED_TO_CART" |
/// "REMOVED_FROM_CART" | "CHECKOUT_STARTED" | "ORDER_CREATED" |
/// "ORDER_CANCELLED" | "SEARCH_QUERY" | "ADMIN_ACTION"
///
/// Append-only event log, one row per tracked user action. Designed to scale
/// to millions of rows: no relations are ever joined for a list read (the
/// admin user-detail page reads a bounded, ordered slice by userId), ids are
/// cuid (no auto-increment contention), and the two composite indexes below
/// cover the only two access patterns this table needs — "recent events for
/// one user" and "recent events of one type across all users". Rows are
/// never updated, only inserted, and are safe to periodically archive/prune
/// by createdAt without touching any other table.
///
/// Only LOGIN/LOGOUT are currently written (see src/lib/auth/session.ts).
/// The remaining event types are modeled and ready, but intentionally not
/// yet wired into the storefront (cart/checkout/search/product-browsing)
/// flows — see the Users admin feature report for why.
model UserActivityEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  /// Free-form event detail (e.g. { productId, sku } for PRODUCT_VIEWED,
  /// { query } for SEARCH_QUERY). Never contains secrets or tokens.
  metadata  Json?
  ipAddress String?
  userAgent String?
  device    String?
  browser   String?
  os        String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("user_activity_events")
}

/// AdminAuditAction values:
/// "ROLE_CHANGED" | "ACCOUNT_DISABLED" | "ACCOUNT_ENABLED" |
/// "MERCHANT_APPROVED" | "MERCHANT_REJECTED" | "MERCHANT_SUSPENDED" |
/// "MERCHANT_STATUS_RESET"
///
/// Append-only. Every sensitive admin action against a user account is
/// recorded here with the old and new value, independent of
/// UserActivityEvent (which tracks the target user's own behavior, not what
/// an admin did to them).
model AdminAuditLog {
  id           String   @id @default(cuid())
  adminUserId  String
  adminUser    User     @relation("AuditLogAdmin", fields: [adminUserId], references: [id])
  targetUserId String
  targetUser   User     @relation("AuditLogTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  action       String
  oldValue     Json?
  newValue     Json?
  createdAt    DateTime @default(now())

  @@index([targetUserId, createdAt])
  @@index([adminUserId, createdAt])
  @@map("admin_audit_logs")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id        String     @id @default(cuid())
  name      String
  nameAr    String?
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("categories")
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  logoUrl   String?
  products  Product[]
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("brands")
}

model Supplier {
  id          String    @id @default(cuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  products    Product[]
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("suppliers")
}

model Product {
  id            String    @id @default(cuid())
  sku           String    @unique
  name          String
  nameAr        String?
  description   String?
  descriptionAr String?
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  brandId       String?
  brand         Brand?    @relation(fields: [brandId], references: [id])
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])

  /// Smallest currency unit (e.g. agorot). Price shown to retail customers.
  retailPriceCents    Int
  /// Smallest currency unit. Only visible to approved wholesale merchants.
  wholesalePriceCents Int
  /// Smallest currency unit. Internal cost, admin-only.
  costCents           Int?

  isActive   Boolean  @default(true)
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  inventoryItems    InventoryItem[]
  stockMovements    StockMovement[]
  orderItems        OrderItem[]
  stockRequestItems StockRequestItem[]
  stockReturnItems  StockReturnItem[]
  images            ProductImage[]
  cartItems         CartItem[]

  @@map("products")
}

// ---------------------------------------------------------------------------
// Cart
// ---------------------------------------------------------------------------

/// One cart per user. No price is stored here — display/checkout price is
/// always computed live from Product.retailPriceCents/wholesalePriceCents
/// based on the viewer's role at read time.
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@map("cart_items")
}

/// One product can have multiple images; at most one is marked `isMain`.
/// `sortOrder` follows the order images were entered in the admin form.
/// mediaType values: "IMAGE" | "VIDEO" — the `isMain` item must always be
/// "IMAGE" (enforced server-side in admin/products/actions.ts) so every
/// call site that reads images[0].url as a static image stays safe.
model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  mediaType String   @default("IMAGE")
  altText   String?
  isMain    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("product_images")
}

// ---------------------------------------------------------------------------
// Inventory
// ---------------------------------------------------------------------------

/// StockLocationType values: "WAREHOUSE" | "REP_CAR"
/// A REP_CAR location always belongs to exactly one SalesRepresentative.
model StockLocation {
  id         String               @id @default(cuid())
  type       String
  name       String
  isDefault  Boolean              @default(false)
  salesRepId String?              @unique
  salesRep   SalesRepresentative? @relation(fields: [salesRepId], references: [id])
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  inventoryItems InventoryItem[]
  movementsFrom  StockMovement[] @relation("MovementFromLocation")
  movementsTo    StockMovement[] @relation("MovementToLocation")

  @@map("stock_locations")
}

/// Current on-hand quantity of a product at a location. Derived data — the
/// source of truth is the StockMovement ledger; this table is a maintained
/// aggregate for fast reads.
model InventoryItem {
  id         String        @id @default(cuid())
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  locationId String
  location   StockLocation @relation(fields: [locationId], references: [id])
  quantity   Int           @default(0)
  updatedAt  DateTime      @updatedAt

  @@unique([productId, locationId])
  @@map("inventory_items")
}

/// StockMovementType values:
/// "PURCHASE_IN" | "TRANSFER" | "SALE_OUT" | "RETURN_IN" | "ADJUSTMENT" |
/// "REP_ASSIGNMENT" | "REP_RETURN"
///
/// Immutable ledger — every inventory change (purchases, transfers, sales,
/// returns, adjustments, rep stock assignment/return) is recorded here and
/// is never edited or deleted, only appended to.
model StockMovement {
  id               String         @id @default(cuid())
  type             String
  productId        String
  product          Product        @relation(fields: [productId], references: [id])
  fromLocationId   String?
  fromLocation     StockLocation? @relation("MovementFromLocation", fields: [fromLocationId], references: [id])
  toLocationId     String?
  toLocation       StockLocation? @relation("MovementToLocation", fields: [toLocationId], references: [id])
  quantity         Int
  previousQuantity Int?
  newQuantity      Int?
  note             String?
  createdById      String?
  createdBy        User?          @relation("StockMovementCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime       @default(now())

  @@map("stock_movements")
}

// ---------------------------------------------------------------------------
// Orders
// ---------------------------------------------------------------------------

/// OrderStatus values:
/// "PENDING" | "CONFIRMED" | "PROCESSING" | "SHIPPED" | "DELIVERED" |
/// "CANCELLED" | "RETURNED"
///
/// OrderSource values: "RETAIL" | "WHOLESALE" | "REP_SALE" | "ADMIN_MANUAL"
model Order {
  id          String @id @default(cuid())
  orderNumber String @unique
  source      String
  status      String @default("PENDING")

  customerId String?
  customer   User?   @relation("OrderCustomer", fields: [customerId], references: [id])

  merchantId String?
  merchant   Merchant? @relation("OrderMerchant", fields: [merchantId], references: [id])

  createdByRepId String?
  createdByRep   SalesRepresentative? @relation("OrderCreatedByRep", fields: [createdByRepId], references: [id])

  currency      String @default("ILS")
  subtotalCents Int
  discountCents Int    @default(0)
  totalCents    Int

  contactName     String?
  contactPhone    String?
  city            String?
  shippingAddress String?
  notes           String?

  /// PaymentMethod values: "CASH_ON_DELIVERY" | "CASH"
  /// See src/lib/constants.ts -> PAYMENT_METHODS
  paymentMethod   String @default("CASH_ON_DELIVERY")
  /// PaymentStatus values: "PENDING" | "PARTIAL" | "PAID" | "FAILED" | "REFUNDED"
  /// See src/lib/constants.ts -> PAYMENT_STATUSES
  paymentStatus   String @default("PENDING")
  /// Smallest currency unit. Amount actually received from the customer so
  /// far — balance due is always computed as totalCents - paidAmountCents,
  /// never stored, so it can never drift out of sync.
  paidAmountCents Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  quantity       Int
  unitPriceCents Int
  totalCents     Int

  @@map("order_items")
}

// ---------------------------------------------------------------------------
// Sales representative stock workflow
// ---------------------------------------------------------------------------

/// StockRequestStatus values: "PENDING" | "REVIEWED" | "PREPARED" | "COMPLETED" | "REJECTED"
/// StockRequestType values: "RESTOCK" (RETURN reserved for a future phase)
///
/// Rep-initiated request for stock to be loaded into their car. Creating,
/// reviewing, and preparing a request never touches InventoryItem/
/// StockMovement — only completeStockRequest() does, exactly once, using
/// each line's approvedQuantity (never requestedQuantity).
model StockRequest {
  id            String              @id @default(cuid())
  /// Friendly business number shown to reps/admin — see generateRequestNumber().
  requestNumber String?             @unique
  salesRepId    String
  salesRep      SalesRepresentative @relation(fields: [salesRepId], references: [id])
  status        String              @default("PENDING")
  type          String              @default("RESTOCK")
  repNote       String?
  adminNote     String?
  reviewedAt    DateTime?
  preparedAt    DateTime?
  completedAt   DateTime?
  rejectedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  items StockRequestItem[]

  @@map("stock_requests")
}

model StockRequestItem {
  id                String       @id @default(cuid())
  stockRequestId    String
  stockRequest      StockRequest @relation(fields: [stockRequestId], references: [id], onDelete: Cascade)
  productId         String
  product           Product      @relation(fields: [productId], references: [id])
  requestedQuantity Int
  /// Set by admin during review. null = not yet reviewed; 0 = rejected/removed line.
  approvedQuantity  Int?

  @@map("stock_request_items")
}

/// StockReturnStatus values: "PENDING" | "APPROVED" | "REJECTED" | "COMPLETED"
model StockReturn {
  id         String              @id @default(cuid())
  salesRepId String
  salesRep   SalesRepresentative @relation(fields: [salesRepId], references: [id])
  status     String              @default("PENDING")
  note       String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  items StockReturnItem[]

  @@map("stock_returns")
}

model StockReturnItem {
  id            String      @id @default(cuid())
  stockReturnId String
  stockReturn   StockReturn @relation(fields: [stockReturnId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Int

  @@map("stock_return_items")
}
