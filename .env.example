# Copy this file to .env for local development — never commit the real .env.

# Local development uses a SQLite file — zero setup, nothing to provision.
DATABASE_URL="file:./dev.db"

# When deploying to production, replace DATABASE_URL with a PostgreSQL
# connection string from your hosting provider (e.g. Neon, Supabase,
# Railway). Example shape only — do not use this value as-is:
# DATABASE_URL="postgresql://user:password@host:5432/ovi_mobile?sslmode=require"
#
# Switching the datasource provider itself (prisma/schema.prisma:
# datasource db { provider = "sqlite" }) is a separate, deliberate step —
# see DEPLOYMENT.md before doing this.

# NODE_ENV is set automatically by the runtime (Next.js sets it during
# `next dev`, `next build`, and `next start`) — do not set it manually here.
# It controls two things in this app:
#   - src/lib/auth/session.ts: session cookies are only marked `secure`
#     (HTTPS-only) when NODE_ENV === "production".
#   - src/lib/prisma.ts: query logging is more verbose outside production.

# Google OAuth ("تسجيل الدخول بواسطة Google" on /login) — optional. If any of
# these three are unset, /auth/google safely redirects back to
# /login?error=google_unavailable instead of erroring. Get credentials from
# https://console.cloud.google.com/apis/credentials — create an OAuth 2.0
# Client ID (Web application) and add the redirect URI below to its
# "Authorized redirect URIs" list.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"
