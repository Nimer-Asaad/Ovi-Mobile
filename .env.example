# Copy this file to .env for local development — never commit the real .env.

# PostgreSQL (Phase 29 — Supabase is the preferred provider for now; Prisma
# Postgres on Vercel is an acceptable alternative). Get these from your
# Supabase project: Project Settings -> Database -> Connection string.
#
# DATABASE_URL is the runtime connection Prisma uses for normal queries —
# for local development against Supabase, the "Session pooler" connection
# string is the safest simple choice (works like a normal long-lived
# Postgres connection, no prepared-statement caveats). Switching to the
# Transaction pooler (port 6543, `?pgbouncer=true`) is a serverless/Vercel
# deployment concern for a later phase, not local development.
#
# DIRECT_URL is the non-pooled connection Prisma uses for `db push` /
# `migrate` — use the direct or session connection here too.
#
# Example shape only — do not use these values as-is:
# DATABASE_URL="postgresql://user:password@host:5432/postgres"
# DIRECT_URL="postgresql://user:password@host:5432/postgres"
DATABASE_URL=
DIRECT_URL=

# NODE_ENV is set automatically by the runtime (Next.js sets it during
# `next dev`, `next build`, and `next start`) — do not set it manually here.
# It controls two things in this app:
#   - src/lib/auth/session.ts: session cookies are only marked `secure`
#     (HTTPS-only) when NODE_ENV === "production".
#   - src/lib/prisma.ts: query logging is more verbose outside production.

# Google OAuth ("تسجيل الدخول بواسطة Google" on /login) — optional. If any of
# these three are unset, /auth/google safely redirects back to
# /login?error=google_unavailable instead of erroring. Get credentials from
# https://console.cloud.google.com/apis/credentials — create an OAuth 2.0
# Client ID (Web application) and add the redirect URI below to its
# "Authorized redirect URIs" list.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"
